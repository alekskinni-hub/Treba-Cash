    /* ── TOC ─────────────────────────────────────── */
    .toc-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-card);
      padding: 1.75rem 2rem;
      margin-bottom: 3rem;
    }
    .toc-card h2 {
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 400;
      color: var(--green-deep);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: .6rem;
    }
    .toc-list {
      list-style: none;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: .3rem .75rem;
    }
    .toc-list li a {
      display: flex;
      align-items: baseline;
      gap: .5rem;
      color: var(--ink-muted);
      text-decoration: none;
      font-size: .9rem;
      padding: .3rem .2rem;
      border-radius: var(--radius-sm);
      transition: color .15s, background .15s, padding-left .15s;
    }
    .toc-list li a:hover { color: var(--green-deep); background: var(--green-light); padding-left: .5rem; }
    .toc-num {
      font-size: .75rem;
      font-weight: 700;
      color: var(--green-mid);
      min-width: 1.4rem;
    }

    /* ── SECTIONS ────────────────────────────────── */
    .section {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-card);
      padding: 2rem 2.25rem;
      margin-bottom: 1.75rem;
      scroll-margin-top: 76px;
      transition: box-shadow .2s;
