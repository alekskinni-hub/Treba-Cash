    .section-icon {
      width: 44px; height: 44px;
      border-radius: var(--radius-md);
      background: var(--green-light);
      border: 1px solid var(--border-strong);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: var(--green-deep);
    }
    .section-title-group { flex: 1; }
    .section-num {
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: var(--green-mid);
      margin-bottom: .2rem;
    }
    .section h2 {
      font-family: var(--font-display);
      font-size: 1.35rem;
      font-weight: 400;
      color: var(--ink);
      line-height: 1.3;
    }

    .section p { color: var(--ink-muted); margin-bottom: 1rem; }
    .section p:last-child { margin-bottom: 0; }

    .section h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--ink);
      margin: 1.5rem 0 .6rem;
    }

    .section ul, .section ol {
      padding-left: 1.25rem;
      color: var(--ink-muted);
      margin-bottom: 1rem;
    }
    .section ul li, .section ol li { margin-bottom: .45rem; }

    /* ── CALLOUT ─────────────────────────────────── */
    .callout {
      border-radius: var(--radius-md);
      padding: 1rem 1.25rem;
      margin: 1.25rem 0;
      display: flex;
      gap: .75rem;
      align-items: flex-start;
    }
    .callout-green {
      background: var(--green-light);
      border: 1px solid var(--border-strong);
    }
    .callout-amber {
      background: #fdf8ec;
      border: 1px solid #e8d898;
    }
    .callout-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: .1rem; }
    .callout p { color: var(--ink-muted); font-size: .92rem; margin: 0; }
    .callout p strong { color: var(--ink); }

    /* ── TABLE ───────────────────────────────────── */
    .table-wrap { overflow-x: auto; margin: 1.25rem 0; border-radius: var(--radius-md); border: 1px solid var(--border); }
    table { width: 100%; border-collapse: collapse; font-size: .88rem; }
    thead tr { background: var(--green-light); }
    th {
      padding: .7rem 1rem;
      text-align: left;
      font-weight: 600;
      color: var(--green-deep);
      border-bottom: 1px solid var(--border-strong);
      white-space: nowrap;
    }
    td {
      padding: .65rem 1rem;
      color: var(--ink-muted);
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    tr:last-child td { border-bottom: none; }
    tbody tr:nth-child(even) { background: #fafcfb; }

    /* ── BROWSER GUIDE ───────────────────────────── */
    .browser-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: .75rem;
      margin: 1.25rem 0;
    }
    .browser-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: .85rem 1rem;
    }
    .browser-card strong { display: block; font-size: .88rem; color: var(--ink); margin-bottom: .3rem; }
    .browser-card span { font-size: .82rem; color: var(--ink-muted); line-height: 1.5; }

    /* ── CONTACT CARD ────────────────────────────── */
    .contact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-top: 1.25rem;
    }
    .contact-item {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 1rem 1.1rem;
      display: flex;
      flex-direction: column;
      gap: .25rem;
    }
    .contact-label { font-size: .75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; color: var(--green-mid); }
    .contact-value { font-size: .93rem; color: var(--ink); word-break: break-all; }
    .contact-value a { color: var(--green-deep); text-decoration: none; }
    .contact-value a:hover { text-decoration: underline; }

    /* ── FOOTER ──────────────────────────────────── */
    .footer {
      text-align: center;
      padding: 2.5rem 1rem 3rem;
      color: var(--ink-faint);
      font-size: .82rem;
      border-top: 1px solid var(--border);
    }
    .footer strong { color: var(--green-deep); }

    /* ── RESPONSIVE ──────────────────────────────── */
    @media (max-width: 600px) {
      .section { padding: 1.5rem 1.25rem; }
      .toc-card { padding: 1.25rem; }
      .section h2 { font-size: 1.15rem; }
    }
  </style>
</head>
