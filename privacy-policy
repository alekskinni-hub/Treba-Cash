  <style>
    :root {
      --green-deep:   #0d6e3f;
      --green-mid:    #18a05a;
      --green-light:  #e8f7ef;
      --green-accent: #25d273;
      --ink:          #111b14;
      --ink-muted:    #4a5e52;
      --ink-faint:    #8ba899;
      --surface:      #f7fbf8;
      --white:        #ffffff;
      --border:       #d4e8dc;
      --border-strong:#a8ccb8;
      --radius-sm:    6px;
      --radius-md:    12px;
      --radius-lg:    20px;
      --shadow-card:  0 2px 16px rgba(13,110,63,.08), 0 1px 4px rgba(13,110,63,.05);
      --shadow-hover: 0 8px 32px rgba(13,110,63,.14);
      --font-body:    'DM Sans', system-ui, sans-serif;
      --font-display: 'DM Serif Display', Georgia, serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      background: var(--surface);
      color: var(--ink);
      font-size: 16px;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
    }

    /* ── TOP BAR ─────────────────────────────────── */
    .topbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 clamp(1rem, 5vw, 3rem);
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
      gap: 1rem;
    }

    .topbar-brand {
      font-family: var(--font-display);
      font-size: 1.25rem;
      color: var(--green-deep);
      letter-spacing: -.5px;
      white-space: nowrap;
    }

    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: .45rem;
      font-size: .875rem;
      font-weight: 500;
      color: var(--green-deep);
      text-decoration: none;
      background: var(--green-light);
      border: 1px solid var(--border-strong);
      padding: .45rem 1.1rem;
      border-radius: 100px;
      transition: background .2s, transform .15s, box-shadow .2s;
      white-space: nowrap;
    }
    .btn-back:hover {
      background: var(--green-mid);
      color: var(--white);
      border-color: var(--green-mid);
      transform: translateX(-2px);
      box-shadow: var(--shadow-hover);
    }
    .btn-back svg { flex-shrink: 0; }

    /* ── HERO ────────────────────────────────────── */
    .hero {
      background: linear-gradient(135deg, var(--green-deep) 0%, #0e4d2c 55%, #07331c 100%);
      color: var(--white);
      padding: clamp(3rem, 8vw, 6rem) clamp(1rem, 5vw, 3rem);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 60% at 50% 120%, rgba(37,210,115,.18) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.25);
      border-radius: 100px;
      padding: .35rem 1rem;
      font-size: .8rem;
      font-weight: 500;
      letter-spacing: .04em;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }
    .hero-badge-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: var(--green-accent);
      box-shadow: 0 0 8px var(--green-accent);
      flex-shrink: 0;
    }
    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 400;
      line-height: 1.2;
      margin-bottom: 1rem;
    }
    .hero-sub {
      color: rgba(255,255,255,.7);
      font-size: 1rem;
      max-width: 600px;
      margin: 0 auto;
    }
    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: .75rem 2rem;
      justify-content: center;
      margin-top: 2rem;
    }
    .hero-meta-item {
      font-size: .85rem;
      color: rgba(255,255,255,.65);
      display: flex;
      align-items: center;
      gap: .4rem;
    }
    .hero-meta-item strong { color: rgba(255,255,255,.9); font-weight: 500; }

    /* ── LAYOUT ──────────────────────────────────── */
    .page-wrap {
      max-width: 900px;
      margin: 0 auto;
      padding: clamp(2rem, 5vw, 4rem) clamp(1rem, 5vw, 2rem);
